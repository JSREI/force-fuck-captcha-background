{
  "name": "force-fuck-captcha-background",
  "version": "1.0.0",
  "main": "dist/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run dev:webpack\" \"npm run dev:electron\"",
    "dev:webpack": "webpack serve --config webpack.config.js",
    "dev:electron": "wait-on http://localhost:9000 && electron .",
    "build": "webpack --config webpack.config.js && electron-builder build",
    "build:webpack": "webpack --config webpack.config.js",
    "build:electron": "electron-builder build",
    "start:static": "electron .",
    "clean": "rm -rf dist && rm -rf node_modules/.cache",
    "rebuild": "npm run clean && npm run build:webpack && npm start",
    "simple-start": "webpack --config webpack.config.js && electron ."
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@types/node": "^22.15.18",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "css-loader": "^7.1.2",
    "electron": "^24.8.8",
    "electron-builder": "^26.0.12",
    "electron-is-dev": "^3.0.1",
    "file-loader": "^6.2.0",
    "html-webpack-plugin": "^5.6.3",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "wait-on": "^8.0.3",
    "webpack": "^5.99.8",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.1"
  },
  "dependencies": {
    "@ant-design/icons": "^6.0.0",
    "antd": "^5.25.1",
    "electron-log": "^5.4.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.6.0"
  },
  "optionalDependencies": {
    "sharp": "^0.33.2"
  },
  "build": {
    "appId": "com.jsrei.captcha.helper",
    "productName": "验证码辅助工具",
    "files": [
      "dist/**/*",
      "node_modules/**/*"
    ],
    "directories": {
      "buildResources": "assets",
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.utilities"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    }
  }
}
